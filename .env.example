# ── Подключение к Confluence (Server / Data Center) ────────────────────────────
# Базовый URL инсталляции без завершающего слэша.
# Пример: https://confluence.company.com  (или с контекстом: https://company.com/confluence)
CONFLUENCE_BASE_URL=https://confluence.company.com

# ── Авторизация ────────────────────────────────────────────────────────────────
# Способ 1 (рекомендуется): Personal Access Token (Bearer).
# Создаётся в Confluence: Profile → Settings → Personal Access Tokens.
CONFLUENCE_PAT=

# Способ 2: логин + пароль (Basic auth). Используется, только если CONFLUENCE_PAT пуст.
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=

# Проверять SSL-сертификат сервера (true/false). Для самоподписанных сертификатов — false.
CONFLUENCE_VERIFY_SSL=true

# ── Троттлинг запросов к Confluence (защита от HTTP 429) ────────────────────────
# ОБЯЗАТЕЛЬНЫЙ параметр. Минимальный интервал (в секундах) между любыми двумя
# запросами к Confluence. Бот обходит поддерево по одному запросу на страницу —
# без паузы это легко упирается в лимит и возвращает 429. Это не «спим всегда»:
# пауза добавляется, только если запросы идут чаще, чем раз в CONFLUENCE_QUERY_DELAY.
# 0 — без паузы. Разумные значения: 0.1–0.5.
CONFLUENCE_QUERY_DELAY=0.2

# Сколько раз повторить запрос, получивший 429, прежде чем сдаться (по умолчанию 3).
# При повторе бот уважает заголовок Retry-After, иначе — экспоненциальный backoff.
CONFLUENCE_MAX_RETRIES=3

# Верхняя граница (сек) одиночного ожидания перед повтором — чтобы огромный
# Retry-After от сервера не подвесил бота надолго (по умолчанию 60).
CONFLUENCE_RETRY_MAX_WAIT=60

# Папка с корневыми (Root/CA) сертификатами для доверенной проверки TLS.
# Если задана и CONFLUENCE_VERIFY_SSL=true — все сертификаты из папки (.pem/.crt/.cer/.der)
# собираются в единый бандл и используются для проверки соединения (вместе с certifi).
# Оставьте пустым, чтобы использовать стандартное хранилище.
CONFLUENCE_CA_CERT_DIR=certs

# ── Дополнительный файл со значениями (напр. секреты) ───────────────────────────
# Если LOAD_ENV_FILE=true — переменные из файла ENV_FILE подгружаются в окружение
# и ПЕРЕОПРЕДЕЛЯЮТ уже заданные (в т.ч. из этого .env). Удобно держать секреты
# (CONFLUENCE_PAT, CONFLUENCE_PASSWORD) отдельно от основного конфига.
LOAD_ENV_FILE=false
ENV_FILE=secrets.env

# ── Что и куда перемещать ───────────────────────────────────────────────────────
# Правила переноса (откуда / куда / по каким лейблам) задаются в отдельном
# YAML-файле — см. rules.example.yaml. Здесь только путь к нему.
# Переопределяется флагом --rules.
RULES_FILE=rules.yaml

# ── Режим демона ────────────────────────────────────────────────────────────────
# Расписание запусков — cron-выражение: «мин час день месяц день_недели».
# Время локальное (часовой пояс машины, где работает бот).
# Примеры:
#   * * * * *      — каждую минуту
#   */5 * * * *    — каждые 5 минут
#   0 * * * *      — в начале каждого часа
#   0 9 * * 1-5    — в 9:00 по будням
#   0 9,18 * * *   — в 9:00 и 18:00
CRON_SCHEDULE=*/5 * * * *

# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Пробный прогон: если true — только логировать, что было бы перемещено, без изменений.
DRY_RUN=false

# ── Health-сервер для проб Kubernetes ───────────────────────────────────────────
# В режиме демона бот поднимает HTTP-сервер здоровья (0.0.0.0):
#   GET /healthz — liveness: 200, пока главный цикл жив и не завис.
#   GET /readyz  — readiness: 200 после успешной стартовой проверки связи с Confluence.
# Порт, который слушает health-сервер (по умолчанию 8080).
HEALTH_PORT=8080

# Порог liveness (сек): если главный поток не подавал признаков жизни дольше
# этого времени — /healthz отвечает 503 и k8s перезапускает под. ВАЖНО: это
# «максимум, сколько главный поток может не отвечать», а НЕ интервал между
# прогонами — heartbeat обновляется и во время сна между запусками по cron,
# поэтому порог не зависит от CRON_SCHEDULE. Берите с запасом на самый долгий
# одиночный запрос (timeout 30с + возможные ретраи 429). По умолчанию 300.
HEALTH_LIVENESS_TIMEOUT=300